# Dashboard environment variables
# Copy this file to `.env` and fill in values.

# Backend API base URL.
# In development, leave blank — Vite proxies /api to localhost:3001.
# In production (standalone dashboard deploy), set to your backend URL:
# VITE_API_BASE_URL=https://api.youragency.gov
VITE_API_BASE_URL=

# Mapbox access token (optional).
# If set, the operations map uses Mapbox dark-v11 tiles.
# If left blank, the dashboard falls back to free OpenFreeMap (OSM) tiles,
# and if the map fails to load entirely, to Google Maps links.
# Get a free token at https://account.mapbox.com/access-tokens/
VITE_MAPBOX_TOKEN=

# Demo mode.
# When the backend has AUTH_ENABLED=false, set this true so the dashboard loads
# without requiring login (public demo). Set false to always require login.
VITE_DEMO_MODE=true

# Inactivity session timeout (minutes) and warning threshold (minutes).
# The warning modal appears at VITE_SESSION_WARNING_MINUTES; the user is logged
# out at VITE_SESSION_TIMEOUT_MINUTES.
VITE_SESSION_TIMEOUT_MINUTES=30
VITE_SESSION_WARNING_MINUTES=28
