{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "@skylab/emergency-sdk": ["packages/emergency-sdk/src"],
      "@skylab/emergency-sdk/*": ["packages/emergency-sdk/src/*"]
    },
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "skipLibCheck": true
  },
  "include": [
    "packages/emergency-sdk/src/**/*.ts",
    "packages/emergency-sdk/src/**/*.tsx",
    "src/**/*.ts",
    "src/**/*.tsx",
    "App.tsx"
  ]
}
