# ER Offline SDK — Server Environment Variables
# Copy this file to .env and fill in the values.
# Never commit .env to version control.

# ─── Database ─────────────────────────────────────────────────────────────────
# PostgreSQL connection string.
#
# Supabase (recommended for Vercel):
#   Transaction pooler URL — use for all Vercel serverless queries:
#   DATABASE_URL="postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
#
#   Direct connection URL — use for Prisma migrations only (npx prisma migrate dev):
#   DIRECT_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres"
#
#   Your Supabase project ref: ongpvemqwnrzdlhglols
#   Connection strings: https://supabase.com/dashboard/project/ongpvemqwnrzdlhglols/settings/database
#
# Local Postgres:
#   DATABASE_URL="postgresql://postgres:password@localhost:5432/er_sdk_dev"
#   DIRECT_URL="postgresql://postgres:password@localhost:5432/er_sdk_dev"

DATABASE_URL=
DIRECT_URL=

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3001

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins in production.
# Leave blank in development (defaults to localhost:5173 and localhost:8081).
# Example: https://emergencysdk.vercel.app,https://youragency.michigan.gov
CORS_ORIGINS=

# ─── Auth ────────────────────────────────────────────────────────────────────
# Required. Minimum 32 characters.
# Generate: openssl rand -hex 32
JWT_SECRET=change_me_dev_only_min_32_chars_xxxx

# ─── Environment ──────────────────────────────────────────────────────────────
NODE_ENV=development

# ─── Push Notifications (Phase 3) ────────────────────────────────────────────
# EXPO_ACCESS_TOKEN=
