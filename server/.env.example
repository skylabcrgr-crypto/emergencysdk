# ER Offline SDK — Server Environment Variables
# Copy this file to .env and fill in the values.
# Never commit .env to version control.

# ─── Database ─────────────────────────────────────────────────────────────────
# PostgreSQL connection string.
#
# Supabase (recommended for Railway / Vercel):
#   IMPORTANT: From cloud hosts (Railway, Vercel) use the POOLER hostname for
#   BOTH URLs. The direct host db.[REF].supabase.co is IPv6-only and is
#   unreachable from Railway/Vercel egress — it will time out on port 5432.
#
#   Transaction pooler (port 6543) — runtime queries:
#   DATABASE_URL="postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
#
#   Session pooler (port 5432) — Prisma Migrate / db push:
#   DIRECT_URL="postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres"
#
#   Your Supabase project ref: ongpvemqwnrzdlhglols
#   Connection strings: https://supabase.com/dashboard/project/ongpvemqwnrzdlhglols/settings/database
#
# Local Postgres:
#   DATABASE_URL="postgresql://postgres:password@localhost:5432/er_sdk_dev"
#   DIRECT_URL="postgresql://postgres:password@localhost:5432/er_sdk_dev"

DATABASE_URL=
DIRECT_URL=

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3001

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins in production.
# Leave blank in development (defaults to localhost:5173 and localhost:8081).
# Example: https://emergencysdk.vercel.app,https://youragency.michigan.gov
CORS_ORIGINS=

# ─── Auth ────────────────────────────────────────────────────────────────────
# Required. Minimum 32 characters.
# Generate: openssl rand -hex 32
JWT_SECRET=change_me_dev_only_min_32_chars_xxxx

# Enforce login/RBAC on protected routes.
#   false → public demo mode (routes permissive; req.user attached if token present)
#   true  → dashboard + operator/admin routes require a valid JWT
AUTH_ENABLED=false

# Access token lifetime (e.g. 30m, 8h, 7d)
TOKEN_TTL=8h

# Base URL of the dashboard — used to build password-reset links in emails.
DASHBOARD_BASE_URL=http://localhost:5173

# Password reset token lifetime (minutes)
PASSWORD_RESET_TOKEN_TTL_MINUTES=30

# Brute-force protection
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_MINUTES=15

# ─── Environment ──────────────────────────────────────────────────────────────
NODE_ENV=development

# ─── Push Notifications (Phase 3) ────────────────────────────────────────────
# EXPO_ACCESS_TOKEN=
